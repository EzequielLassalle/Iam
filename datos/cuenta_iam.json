    "CreditosABAC": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "EC2SoloDeMiProyecto",
          "Effect": "Allow",
          "Action": [
            "ec2:StartInstances",
            "ec2:StopInstances",
            "ec2:DescribeInstances"
          ],
          "Resource": "*",
          "Condition": {
            "StringEquals": {
              "aws:ResourceTag/Proyecto": "${aws:PrincipalTag/Proyecto}"
            }
          }
        }
      ]
    },
    "NegarSinMFA": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "NegarTodoSinMFA",
          "Effect": "Deny",
