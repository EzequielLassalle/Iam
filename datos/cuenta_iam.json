          "Resource": "*",
          "Condition": {
            "Bool": {
              "aws:MultiFactorAuthPresent": "false"
            }
          }
        }
      ]
    },
    "BoundaryS3ReadOnly": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "TechoS3YReadOnly",
          "Effect": "Allow",
          "Action": [
